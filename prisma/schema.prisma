generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "sqlite"
  url       = "file:./db/custom.db"
}

model Category {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  image     String    @default("")
  sortOrder Int       @default(0)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
}

model Product {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String    @default("")
  unit        String    @default("1 pc")
  price       Float     @default(0)
  mrp         Float     @default(0)
  stock       Int       @default(0)
  minQuantity Int       @default(1)
  image       String    @default("")
  isAvailable Boolean   @default(true)
  isFeatured  Boolean   @default(false)
  isBestSelling Boolean @default(false)
  categoryId  String
  category    Category  @relation(fields: [categoryId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  orderItems  OrderItem[]
}

model User {
  id           String    @id @default(cuid())
  name         String
  mobile       String    @unique
  businessName String    @default("")
  email        String    @default("")
  isAdmin      Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  orders       Order[]
}

model Order {
  id            String      @id @default(cuid())
  orderId       String      @unique
  customerName  String
  mobile        String
  businessName  String      @default("")
  totalAmount   Float
  paymentMethod String      @default("Cash at Shop")
  paymentStatus String      @default("Pending")
  orderStatus   String      @default("Pending")
  pickupStatus  String      @default("Not Ready")
  specialNote   String      @default("")
  pickupDate    String      @default("")
  userId        String?
  user          User?       @relation(fields: [userId], references: [id])
  items         OrderItem[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model OrderItem {
  id          String  @id @default(cuid())
  productName String
  quantity    Int
  price       Float
  total       Float
  orderId     String
  order       Order   @relation(fields: [orderId], references: [id])
  product     Product @relation(fields: [productId], references: [id])
  productId   String
  createdAt   DateTime @default(now())
}

model Otp {
  id        String   @id @default(cuid())
  mobile    String
  otp       String
  verified  Boolean  @default(false)
  expiresAt DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())
}